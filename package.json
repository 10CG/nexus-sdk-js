{
  "name": "@nexus/sdk",
  "version": "0.1.0-alpha",
  "description": "Nexus AI Cognitive Services JavaScript SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nexus",
    "ai",
    "cognitive-services",
    "memory",
    "knowledge-graph",
    "context"
  ],
  "author": "10CG Team <dev@10cg.pub>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://forgejo.10cg.pub/10CG/nexus-sdk-js"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsup": "^8.0.2",
    "vitest": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
